{
  "name": "@mossen/cli",
  "private": false,
  "type": "module",
  "version": "1.4.0-dev",
  "description": "Mossen personal software-engineering AI CLI with configurable providers.",
  "bin": {
    "mossen": "./bin/mossen.js"
  },
  "exports": {
    ".": "./bin/mossen.js",
    "./sdk": {
      "types": "./entrypoints/sdk/index.ts",
      "import": "./entrypoints/sdk/index.ts",
      "default": "./entrypoints/sdk/index.ts"
    },
    "./contract": "./dev/mossen-contract.json"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.0.0"
