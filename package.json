    "start": "./run-mossen.sh",
    "help": "./run-mossen.sh --help",
    "start:source": "./run-mossen.sh",
    "link:global": "npm link",
    "typecheck": "tsc --noEmit",
    "test:memory-sidecar": "bun test services/memorySidecar/__tests__/ memory-sidecar/src/ingest/__tests__/ memory-sidecar/src/adapter/__tests__/ memory-sidecar/src/storage/__tests__/ memory-sidecar/src/agent/__tests__/ memory-sidecar/src/retrieval/__tests__/ memory-sidecar/src/redaction/__tests__/ memory-sidecar/src/profile/__tests__/ memory-sidecar/src/management/__tests__/",
